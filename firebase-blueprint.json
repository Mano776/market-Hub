{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "vendor", "customer"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "active"] },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listing by a vendor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vendorId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "inventory": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vendorId", "name", "price", "inventory"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "commissionAmount": { "type": "number" },
        "vendorEarnings": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "vendorId", "items", "totalAmount"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercentage": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["code", "discountPercentage", "expiryDate"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "customerId", "rating", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "commissionPercentage": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product listings" },
    "/orders/{orderId}": { "schema": "Order", "description": "Order records" },
    "/coupons/{couponCode}": { "schema": "Coupon", "description": "Discount coupons" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product reviews" },
    "/settings/global": { "schema": "Settings", "description": "Global settings" }
  }
}
