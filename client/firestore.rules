rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, name, role (admin|vendor|customer), status (pending|approved|rejected|active), createdAt
    //
    // Collection: products
    // Fields: id, vendorId, name, description, price, inventory, category, images, status, createdAt
    //
    // Collection: orders
    // Fields: id, customerId, vendorId, items, totalAmount, commissionAmount, vendorEarnings, status, createdAt
    //
    // Collection: coupons
    // Fields: code, discountPercentage, expiryDate, active
    //
    // Collection: reviews
    // Fields: id, productId, customerId, rating, comment, createdAt
    //
    // Collection: settings
    // Fields: commissionPercentage
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mk6112004@gmail.com" && request.auth.token.email_verified == true));
    }

    function isVendor() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.role in ['admin', 'vendor', 'customer'] &&
             data.status in ['pending', 'approved', 'rejected', 'active'] &&
             data.email is string && data.email.size() < 100 &&
             data.name is string && data.name.size() < 100;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['vendorId', 'name', 'price', 'inventory']) &&
             data.price is number && data.price >= 0 &&
             data.inventory is number && data.inventory >= 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'customerId', 'rating', 'status']) &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.comment is string && data.comment.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) &&
                    (request.resource.data.role != 'admin' || isAdmin());
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isVendor() && isValidProduct(request.resource.data) && request.resource.data.vendorId == request.auth.uid;
      allow update: if (isVendor() && resource.data.vendorId == request.auth.uid) || isAdmin();
      allow delete: if (isVendor() && resource.data.vendorId == request.auth.uid) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.vendorId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if (isVendor() && resource.data.vendorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) || isAdmin();
    }

    match /coupons/{couponCode} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isOwner(resource.data.customerId) || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
